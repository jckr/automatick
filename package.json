{
  "name": "automatick-monorepo",
  "private": true,
  "version": "0.2.0",
  "description": "Monorepo for the automatick library",
  "author": "jckr",
  "license": "MIT",
  "repository": "jckr/automatick",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build:packages": "npm run build -w automatick",
    "test": "run-s test:unit test:lint",
    "test:lint": "eslint .",
    "test:unit": "vitest run --config packages/automatick/vitest.config.ts",
    "test:e2e": "playwright test",
    "test:watch": "vitest --config packages/automatick/vitest.config.ts",
    "dev": "npm run dev -w automatick-docs"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.0"
  }
}
